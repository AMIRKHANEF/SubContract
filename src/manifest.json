{
    "manifest_version": 3,
    "name": "SubContract",
    "version": "0.0.1",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "action": {
        "default_popup": "index.html",
        "default_icon": "icons/icon48.png"
    },
    "background": {
        "service_worker": "src/background.ts"
    },
    "icons": {
        "48": "icons/icon48.png"
    }
}
