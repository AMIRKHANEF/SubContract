{
    "manifest_version": 3,
    "name": "SubContract",
    "description": "Daily-use dev utilities for Solidity developers building on Polkadot ecosystem.",
    "version": "0.0.1",
    "permissions": [
        "storage",
        "activeTab",
        "clipboardRead"
    ],
    "action": {
        "default_popup": "index.html",
        "default_icon": "logo/logo-SubContract.png"
    },
    "background": {
        "service_worker": "src/background.ts"
    },
    "icons": {
        "128": "logo/logo-SubContract-128.png",
        "48": "logo/logo-SubContract-48.png",
        "16": "logo/logo-SubContract-16.png"
    }
}
